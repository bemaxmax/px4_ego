<?xml version="1.0"?>
<robot name="px4_frame_links">

  <link name="base_footprint"/>

  <joint name="base_link_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link"/>

  <joint name="base_link_to_camera_link" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.15 0.03 0.21" rpy="0 0 0"/>
  </joint>

  <link name="camera_link"/>

  <joint name="base_link_to_lidar_link" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.12 0 0.315" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link"/>

  <!-- Compatibility alias for the older lidar-only model. -->
  <joint name="base_link_to_link" type="fixed">
    <parent link="base_link"/>
    <child link="link"/>
    <origin xyz="0.12 0 0.315" rpy="0 0 0"/>
  </joint>

  <link name="link"/>
</robot>
